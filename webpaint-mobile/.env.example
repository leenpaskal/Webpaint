# Local development — point the mobile app at the locally-running web
# backend.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# For the deployed Netlify build the value below is injected by
# webpaint-mobile/netlify.toml at build time. You don't need to set it
# manually for production.
#
#   EXPO_PUBLIC_API_BASE_URL=https://webpaint-web.netlify.app/api
