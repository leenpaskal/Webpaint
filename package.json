{
  "name": "webpaint-project",
  "version": "1.0.0",
  "description": "Webpaint website project management system",
  "license": "ISC",
  "author": "",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "webpaint-web",
    "webpaint-mobile"
  ],
  "scripts": {
    "dev": "concurrently -n web,mobile -c blue,green \"npm run dev -w webpaint-web\" \"npm run dev -w webpaint-mobile\"",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
